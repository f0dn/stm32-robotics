{
    "configurations": [
        {
            "name": "STM32",
            "compilerPath": "/opt/homebrew/bin/arm-none-eabi-gcc",
            "intelliSenseMode": "gcc-arm",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "compileCommands": "${workspaceFolder}/build/Debug/compile_commands.json",
            "includePath": [
                "${workspaceFolder}/Core/Inc",
                "${workspaceFolder}/Drivers/STM32F3xx_HAL_Driver/Inc",
                "${workspaceFolder}/Drivers/STM32F3xx_HAL_Driver/Inc/Legacy",
                "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32F3xx/Include",
                "${workspaceFolder}/Drivers/CMSIS/Include"
            ],
            "defines": [
                "STM32F303xE",
                "USE_HAL_DRIVER"
            ]
        }
    ],
    "version": 4
}